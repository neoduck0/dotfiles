#!/usr/bin/env python3

import os
import json


def main():
    todo_file = os.environ.get("TODO_FILE")
    if not todo_file or not os.path.isfile(todo_file):
        print(json.dumps({"text": ""}))
        return

    with open(todo_file) as f:
        count = sum(1 for line in f if line.strip())

    print(
        json.dumps(
            {
                "text": " " + str(count)
            }
        )
    )


if __name__ == "__main__":
    main()
